{
  "name": "pi-xai",
  "version": "0.3.0",
  "description": "Pi extension for xAI text generation via Responses API — reasoning, multi-agent, structured outputs, tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/luxus/pi-xai.git"
  },
  "type": "module",
  "keywords": [
    "pi-package",
    "xai",
    "grok",
    "responses-api",
    "multi-agent"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "echo 'nothing to build'",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  },
  "files": [
    "index.ts",
    "xai-*.ts",
    "tsconfig.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "lint-staged": {
    "**/*.ts": [
      "tsc --noEmit",
      "vitest run"
    ]
  }
}
